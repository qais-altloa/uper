class IntelligentAlgorithmSelector:
    """Automatically selects the best algorithm based on current situation"""
    
    def __init__(self, grid, drivers, requests):
        self.grid = grid
        self.drivers = drivers
        self.requests = requests
        self.decision_log = []
    
    def analyze_situation(self):
        """Analyze current situation and return recommendations"""
        grid_size = self.grid.rows * self.grid.cols
        num_drivers = len([d for d in self.drivers if d.available])
        num_requests = len(self.requests)
        obstacle_density = self.calculate_obstacle_density()
        driver_density = num_drivers / grid_size if grid_size > 0 else 0
        
        analysis = {
            'grid_size': grid_size,
            'num_drivers': num_drivers,
            'num_requests': num_requests,
            'obstacle_density': obstacle_density,
            'driver_density': driver_density,
            'recommended_selector': None,
            'recommended_pathfinder': 'BFS',
            'use_optimization': False,
            'reasoning': []
        }
        
        # Decision logic for driver selection algorithm
        if num_requests > 2 and num_drivers >= num_requests:
            analysis['recommended_selector'] = 'DP'
            analysis['use_optimization'] = True
            analysis['reasoning'].append(f"Multiple requests ({num_requests}) with sufficient drivers ({num_drivers}) → Using DP for optimal assignment")
        
        elif grid_size > 5000 or (self.grid.rows > 30 and self.grid.cols > 30):
            analysis['recommended_selector'] = 'DIVIDE_CONQUER'
            analysis['reasoning'].append(f"Large grid ({self.grid.rows}x{self.grid.cols}) → Using Divide & Conquer for faster regional search")
        
        elif obstacle_density > 0.4:
            analysis['recommended_selector'] = 'GREEDY'
            analysis['reasoning'].append(f"High obstacle density ({obstacle_density:.1%}) → Using Greedy for simpler, faster decisions")
        
        elif driver_density < 0.05:
            analysis['recommended_selector'] = 'DIVIDE_CONQUER'
            analysis['reasoning'].append(f"Low driver density ({driver_density:.2%}) → Using Divide & Conquer to efficiently locate sparse drivers")
        
        else:
            analysis['recommended_selector'] = 'GREEDY'
            analysis['reasoning'].append(f"Standard conditions → Using Greedy for fast nearest-driver selection")
        
        # Always use BFS for pathfinding due to obstacles
        if obstacle_density > 0:
            analysis['reasoning'].append(f"BFS pathfinding required due to obstacles ({obstacle_density:.1%} of grid blocked)")
        
        self.decision_log = analysis['reasoning']
        return analysis
    
    def calculate_obstacle_density(self):
        """Calculate percentage of blocked cells"""
        blocked = 0
        total = self.grid.rows * self.grid.cols
        for i in range(self.grid.rows):
            for j in range(self.grid.cols):
                if self.grid.is_blocked(i, j):
                    blocked += 1
        return blocked / total if total > 0 else 0
    
    def select_driver(self, passenger, use_dp_assignment=False, all_requests=None):
        """Select driver based on analyzed situation"""
        analysis = self.analyze_situation()
        
        print("\n" + "="*60)
        print("🤖 INTELLIGENT ALGORITHM SELECTOR ANALYSIS")
        print("="*60)
        for reasoning in analysis['reasoning']:
            print(f"   • {reasoning}")
        print("="*60)
        
        if analysis['use_optimization'] and use_dp_assignment and all_requests:
            return None, analysis  # Will use DP for all requests
        
        elif analysis['recommended_selector'] == 'DIVIDE_CONQUER':
            dc = DivideAndConquer(self.grid)
            driver = dc.search(self.drivers, passenger)
            if driver:
                return driver, analysis
        
        # Default to GREEDY
        greedy = GreedySelector()
        driver, distance = greedy.select(self.drivers, passenger)
        return driver, analysis
    
    def print_decision_summary(self):
        """Print summary of algorithm decisions"""
        print("\n" + "="*60)
        print("📊 ALGORITHM DECISION SUMMARY")
        print("="*60)
        for i, reasoning in enumerate(self.decision_log, 1):
            print(f"   {i}. {reasoning}")
        print("="*60)


