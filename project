class TripManager:
    """Manages individual trips and animations"""
    
    COST_PER_STEP = 5
    TIME_PER_STEP = 2
    
    def __init__(self, grid, bfs_solver):
        self.grid = grid
        self.bfs = bfs_solver
        self.algorithms_used = {
            'bfs': False,
            'greedy': False,
            'divide_conquer': False,
            'dp': False
        }
    
    def animate_movement(self, driver, path, purpose):
        """Animate driver movement step by step"""
        print(f"\n🎬 Driver {driver.id} moving to {purpose}...")
        
        for i, step in enumerate(path):
            self.grid.update_driver_position(driver, step)
            self.grid.display(f"Step {i+1}/{len(path)} - Moving to {purpose}")
            time.sleep(0.2)
        
        print(f"✅ Driver {driver.id} reached {purpose}!")


class RideMatcher:
    """Main system that matches drivers with ride requests"""
    
    def __init__(self, grid, drivers):
        self.grid = grid
        self.drivers = drivers
        self.bfs = BFS()
        self.trip_manager = TripManager(grid, self.bfs)
        self.algorithm_log = []
        self.analyzer = None
    
    def log_algorithm(self, algo_name, description):
        """Log algorithm usage"""
        self.algorithm_log.append({
            'algorithm': algo_name,
            'description': description
        })
        print(f"📊 [{algo_name}] {description}")
    
    def process_requests_auto(self, requests):
        """Process requests with automatic algorithm selection"""
        self.analyzer = IntelligentAlgorithmSelector(self.grid, self.drivers, requests)
        analysis = self.analyzer.analyze_situation()
        self.analyzer.print_decision_summary()
        
        results = []
        
        # Use DP if recommended and multiple requests
        if analysis['use_optimization'] and len(requests) > 1:
            print("\n🎯 SYSTEM DECISION: Using Dynamic Programming for optimal multi-request assignment")
            self.log_algorithm("DP", f"Optimizing assignment of {len(requests)} requests")
            results = self.process_multiple_requests_dp(requests)
        else:
            # Process each request individually
            for request in requests:
                result = self.process_single_request_auto(request)
                if result:
                    results.append(result)
        
        return results
    
    def process_single_request_auto(self, request):
        """Process a single request with automatic algorithm selection"""
        passenger = request.passenger
        print(f"\n{'='*60}")
        print(f"🔄 Processing Request {request.id}")
        print(f"   Pickup: {passenger.pickup}")
        print(f"   Destination: {passenger.destination}")
        print(f"{'='*60}")
        
        # Step 1: Automatically select algorithm and find driver
        driver, analysis = self.analyzer.select_driver(passenger, use_dp_assignment=False)
        
        if not driver:
            print("❌ No driver available!")
            return None
        
        selected_algo = analysis['recommended_selector']
        self.log_algorithm(selected_algo, f"Selected driver {driver.id} for request {request.id}")
        
        # Step 2: BFS Path to pickup (always use BFS due to obstacles)
        self.log_algorithm("BFS", f"Finding shortest path from driver to pickup")
        dist_to_pickup, path_to_pickup = self.bfs.find_path(self.grid, driver.position, passenger.pickup)
        
        if dist_to_pickup == math.inf:
            print(f"❌ No path from driver {driver.id} to pickup!")
            return None
        
        self.log_algorithm("BFS", f"Path found: {dist_to_pickup} steps")
        
        # Step 3: Show driver info
        print(f"\n🚗 Assigned Driver Details:")
        print(f"   ID: {driver.id}")
        print(f"   Name: {driver.name}")
        print(f"   Car: {driver.car}")
        print(f"   Phone: {driver.phone}")
        print(f"   Current Position: {driver.position}")
        
        # Step 4: Animate driver moving to pickup
        self.trip_manager.animate_movement(driver, path_to_pickup, f"pickup point {passenger.pickup}")
        
        # Step 5: Show trip cost and time to pickup
        cost_to_pickup = dist_to_pickup * self.trip_manager.COST_PER_STEP
        time_to_pickup = dist_to_pickup * self.trip_manager.TIME_PER_STEP
        
        print(f"\n💰 Trip to Pickup:")
        print(f"   Distance: {dist_to_pickup} steps")
        print(f"   Cost: {cost_to_pickup} EGP")
        print(f"   Time: {time_to_pickup} minutes")
        
        # Step 6: Get passenger agreement
        input("\n⏎ Press Enter when passenger agrees to start the ride...")
        
        # Step 7: BFS Path to destination
        self.log_algorithm("BFS", f"Finding shortest path from pickup to destination")
        dist_to_dest, path_to_dest = self.bfs.find_path(self.grid, passenger.pickup, passenger.destination)
        
        if dist_to_dest == math.inf:
            print(f"❌ No path from pickup to destination!")
            return None
        
        self.log_algorithm("BFS", f"Path found: {dist_to_dest} steps")
        
        # Step 8: Animate driver moving to destination
        # Clear pickup marker
        self.grid.grid[passenger.pickup.row][passenger.pickup.col] = '0'
        self.trip_manager.animate_movement(driver, path_to_dest, f"destination {passenger.destination}")
        
        # Step 9: Calculate total trip
        total_distance = dist_to_pickup + dist_to_dest
        total_cost = total_distance * self.trip_manager.COST_PER_STEP
        total_time = total_distance * self.trip_manager.TIME_PER_STEP
        
        result = {
            'request': request,
            'driver': driver,
            'dist_to_pickup': dist_to_pickup,
            'dist_to_dest': dist_to_dest,
            'total_distance': total_distance,
            'cost': total_cost,
            'time': total_time,
            'algorithm_log': self.algorithm_log.copy(),
            'selected_algorithm': selected_algo
        }
        
        return result
    
    def process_multiple_requests_dp(self, requests):
        """Process multiple requests using DP optimization"""
        self.log_algorithm("DP", f"Optimizing assignment of {len(requests)} requests to {len(self.drivers)} drivers")
        
        assigner = DPAssigner(self.drivers, requests, use_bfs=True, grid=self.grid)
        assignments, total_cost = assigner.assign()
        
        if not assignments:
            print("❌ DP assignment failed!")
            return []
        
        self.log_algorithm("DP", f"Optimal assignment found with total cost {total_cost}")
        
        # Show assignment plan
        print("\n📋 OPTIMAL ASSIGNMENT PLAN:")
        for req_idx, drv_idx in assignments:
            request = requests[req_idx]
            driver = self.drivers[drv_idx]
            print(f"   Request {request.id} → Driver {driver.id} ({driver.name})")
        
        input("\n⏎ Press Enter to execute assignments...")
        
        results = []
        for req_idx, drv_idx in assignments:
            request = requests[req_idx]
            driver = self.drivers[drv_idx]
            
            # Process individual trip
            result = self.process_single_request_with_assigned_driver(request, driver)
            if result:
                result['dp_optimized'] = True
                results.append(result)
                driver.available = False
        
        return results
    
    def process_single_request_with_assigned_driver(self, request, driver):
        """Process request with pre-assigned driver"""
        passenger = request.passenger
        
        print(f"\n{'='*60}")
        print(f"🔄 Executing DP-Assigned Request {request.id}")
        print(f"   Driver: {driver.id} ({driver.name})")
        print(f"   Pickup: {passenger.pickup}")
        print(f"   Destination: {passenger.destination}")
        print(f"{'='*60}")
        
        # BFS Path to pickup
        dist_to_pickup, path_to_pickup = self.bfs.find_path(self.grid, driver.position, passenger.pickup)
        
        if dist_to_pickup == math.inf:
            return None
        
        # Show driver info
        print(f"\n🚗 Driver Details:")
        print(f"   ID: {driver.id}")
        print(f"   Name: {driver.name}")
        print(f"   Car: {driver.car}")
        print(f"   Phone: {driver.phone}")
        
        # Animate to pickup
        self.trip_manager.animate_movement(driver, path_to_pickup, f"pickup point {passenger.pickup}")
        
        # BFS to destination
        dist_to_dest, path_to_dest = self.bfs.find_path(self.grid, passenger.pickup, passenger.destination)
        
        if dist_to_dest == math.inf:
            return None
        
        # Clear pickup marker
        self.grid.grid[passenger.pickup.row][passenger.pickup.col] = '0'
        
        input("\n⏎ Press Enter to continue to destination...")
        
        # Animate to destination
        self.trip_manager.animate_movement(driver, path_to_dest, f"destination {passenger.destination}")
        
        total_distance = dist_to_pickup + dist_to_dest
        total_cost = total_distance * self.trip_manager.COST_PER_STEP
        total_time = total_distance * self.trip_manager.TIME_PER_STEP
        
        result = {
            'request': request,
            'driver': driver,
            'dist_to_pickup': dist_to_pickup,
            'dist_to_dest': dist_to_dest,
            'total_distance': total_distance,
            'cost': total_cost,
            'time': total_time
        }
        
        return result
    
    def generate_report(self, results):
        """Generate final report showing algorithm roles"""
        print("\n" + "="*80)
        print("📋 FINAL TRIP REPORT")
        print("="*80)
        
        total_cost = 0
        total_time = 0
        
        for result in results:
            request = result['request']
            driver = result['driver']
            
            print(f"\n🚕 TRIP {request.id}:")
            print(f"   Driver: {driver.name} (ID: {driver.id})")
            print(f"   Vehicle: {driver.car}")
            print(f"   Contact: {driver.phone}")
            print(f"   Selected by: {result.get('selected_algorithm', 'DP' if result.get('dp_optimized') else 'System Decision')}")
            print(f"   Distance to pickup: {result['dist_to_pickup']} steps")
            print(f"   Distance to destination: {result['dist_to_dest']} steps")
            print(f"   Total distance: {result['total_distance']} steps")
            print(f"   Cost: {result['cost']} EGP")
            print(f"   Time: {result['time']} minutes")
            
            total_cost += result['cost']
            total_time += result['time']
        
        print("\n" + "="*80)
        print("💰 SYSTEM SUMMARY")
        print("="*80)
        print(f"   Total trips completed: {len(results)}")
        print(f"   Total cost: {total_cost} EGP")
        print(f"   Total time: {total_time} minutes")
        
        print("\n" + "="*80)
        print("🧠 ALGORITHMS USED & THEIR ROLES")
        print("="*80)
        
        algorithms_info = {
            'Greedy': 'Selected the nearest available driver to minimize initial response time. Best for: small grids, low obstacle density, quick decisions.',
            'Divide & Conquer': 'Divided the grid into 4 regions for efficient driver search. Best for: large grids, sparse driver distribution.',
            'BFS': 'Found the shortest path avoiding obstacles (X cells) to minimize travel distance. Essential when obstacles are present.',
            'DP': 'Optimized multiple requests assignment to minimize total system cost. Best for: multiple simultaneous requests with sufficient drivers.'
        }
        
        for algo, description in algorithms_info.items():
            print(f"\n📌 {algo}:")
            print(f"   {description}")
        
        print("\n" + "="*80)
        print("🎯 SYSTEM DECISION LOGIC")
        print("="*80)
        if self.analyzer:
            for reasoning in self.analyzer.decision_log:
                print(f"   • {reasoning}")
        
        print("="*80)


